{
  "checks": {
    "executableBits": { 
      "strict": 2, 
      "autoStage": true 
    },
    "lineEndings": { 
      "enforce": true 
    },
    "filePermissions": { 
      "warnOnGroupWrite": true 
    }
  },
  "git": {
    "autoInstallHooks": true,
    "releaseConfirm": {
      "strictDefault": false
    },
    "preAddLint": {
      "enabled": true,
      "spotless": true
    }
  }, 
  "make": { 
    "defaultTarget": "verify"
  },
  "planning": {
    "dir": "docs/planning",
    "ideas": "IDEAS.md",
    "todo": "TODO.md",
    "checklist": "PROMOTION_CHECKLIST.md"
  }
}
